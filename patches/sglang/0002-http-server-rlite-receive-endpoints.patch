+def _make_rlite_update_request(payload, *, load_format: str, flush_cache: bool):
+    serialized_payload = MultiprocessingSerializer.serialize(
+        [("__rlite_payload__", payload)],
+        output_str=True,
+    )
+    tp_size = int(getattr(_global_state.tokenizer_manager.server_args, "tp_size", 1) or 1)
+    return UpdateWeightsFromTensorReqInput(
+        serialized_named_tensors=[serialized_payload for _ in range(tp_size)],
+        load_format=load_format,
+        flush_cache=flush_cache,
+    )
+
+
+def _decode_rlite_messages(message: str):
+    from rlite.integrations import decode_payload
+
+    return [decode_payload(part) for part in message.split(" | ") if part]
+
