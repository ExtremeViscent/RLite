+@app.post("/rlite/prepare_receive")
+@auth_level(AuthLevel.ADMIN_OPTIONAL)
+async def rlite_prepare_receive(obj: Dict[str, str], request: Request):
+    from rlite.integrations import decode_payload, encode_payload
+
+    payload = decode_payload(obj["payload_b64"])
+    req = _make_rlite_update_request(
+        payload,
+        load_format="rlite_prepare_receive",
+        flush_cache=False,
+    )
+    success, message = await _global_state.tokenizer_manager.update_weights_from_tensor(
+        req, request
+    )
+    if not success:
+        return ORJSONResponse(
+            {"success": False, "message": message},
+            status_code=HTTPStatus.BAD_REQUEST,
+        )
+    worker_payloads = _decode_rlite_messages(message)
+    result_payload = {
+        "rank_descriptors": {
+            int(item["rank"]): item["rank_descriptor"] for item in worker_payloads
+        },
+        "requires_staging": any(bool(item.get("requires_staging", False)) for item in worker_payloads),
+        "fallback_bytes": sum(int(item.get("fallback_bytes", 0)) for item in worker_payloads),
+    }
+    return ORJSONResponse(
+        {
+            "success": True,
+            "payload_b64": encode_payload(result_payload),
+            "requires_staging": result_payload["requires_staging"],
+            "fallback_bytes": result_payload["fallback_bytes"],
+        }
+    )
+
+
+@app.post("/rlite/commit_receive")
+@auth_level(AuthLevel.ADMIN_OPTIONAL)
+async def rlite_commit_receive(obj: Dict[str, str], request: Request):
+    from rlite.integrations import decode_payload, encode_payload
+
+    payload = decode_payload(obj["payload_b64"])
+    req = _make_rlite_update_request(
+        payload,
+        load_format="rlite_commit_receive",
+        flush_cache=True,
+    )
+    success, message = await _global_state.tokenizer_manager.update_weights_from_tensor(
+        req, request
+    )
+    content = {"success": success}
+    if success:
+        content["payload_b64"] = encode_payload(_decode_rlite_messages(message))
+    else:
+        content["message"] = message
+    return ORJSONResponse(
+        content, status_code=200 if success else HTTPStatus.BAD_REQUEST
+    )
+
